using Python.Runtime;
using UnityEngine;
using System;

public class PythonManager : MonoBehaviour
{
    // 配置你的Python环境路径
    private string pythonHome = @"C:\Path\To\Your\VirtualEnv"; // 或嵌入版路径
    private string pythonDllName = "python39.dll"; // 根据你的Python版本修改

    void Start()
    {
        ConfigurePythonEnvironment();
        InitializePythonEngine();
        TestPythonIntegration();
    }

    void ConfigurePythonEnvironment()
    {
        // 1. 设置Python主目录
        Environment.SetEnvironmentVariable("PYTHONHOME", pythonHome);
        
        // 2. 设置Python模块搜索路径
        string sitePackages = $"{pythonHome}/Lib/site-packages";
        Environment.SetEnvironmentVariable("PYTHONPATH", $"{pythonHome};{sitePackages}");
        
        // 3. 明确指定Python的DLL文件
        string dllPath = System.IO.Path.Combine(pythonHome, pythonDllName);
        Environment.SetEnvironmentVariable("PYTHONNET_PYDLL", dllPath);
        // 或者直接赋值给 Runtime.PythonDLL
        Runtime.PythonDLL = dllPath; [2,5](@ref)
        
        Debug.Log($"Python environment configured. HOME: {pythonHome}, DLL: {dllPath}");
    }

    void InitializePythonEngine()
    {
        try
        {
            PythonEngine.Initialize(); // 初始化Python引擎
            PythonEngine.BeginAllowThreads(); // 允许线程操作[2](@ref)
            Debug.Log("Python engine initialized successfully.");
        }
        catch (Exception e)
        {
            Debug.LogError($"Failed to initialize Python engine: {e.Message}");
        }
    }

    void TestPythonIntegration()
    {
        using (Py.GIL()) // 获取全局解释器锁，确保线程安全[1,3](@ref)
        {
            try
            {
                dynamic sys = Py.Import("sys");
                Debug.Log($"Python version: {sys.version}");
                
                // 尝试导入已安装的包，如numpy
                dynamic np = Py.Import("numpy");
                Debug.Log($"NumPy version: {np.__version__}");
                
                // 调用一个简单的函数
                dynamic result = np.sqrt(16);
                Debug.Log($"Square root of 16 is: {result}");
            }
            catch (PythonException e)
            {
                Debug.LogError($"Python error: {e.Message}");
            }
        }
    }

    void OnApplicationQuit()
    {
        if (PythonEngine.IsInitialized)
        {
            PythonEngine.Shutdown(); // 应用退出时关闭Python引擎[1,3](@ref)
            Debug.Log("Python engine shut down.");
        }
    }
}